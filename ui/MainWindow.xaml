<Window x:Class="HKBuildUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HKBuild GUI" Height="620" Width="720"
        MinHeight="480" MinWidth="560"
        Background="#1E1E1E" Foreground="#DCDCDC"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Dark theme colours -->
        <SolidColorBrush x:Key="PanelBg"   Color="#2D2D2D"/>
        <SolidColorBrush x:Key="InputBg"   Color="#3C3C3C"/>
        <SolidColorBrush x:Key="BorderCol" Color="#555555"/>
        <SolidColorBrush x:Key="AccentCol" Color="#0078D4"/>
        <SolidColorBrush x:Key="LogBg"     Color="#141414"/>

        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="#DCDCDC"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="#DCDCDC"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentCol}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="0,8"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DropZone" TargetType="Border">
            <Setter Property="BorderBrush"     Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background"      Value="{StaticResource PanelBg}"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#AAAAAA"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="LogBox" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource LogBg}"/>
            <Setter Property="Foreground"        Value="#CCCCCC"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FontFamily"        Value="Consolas, Courier New"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="IsReadOnly"        Value="True"/>
            <Setter Property="TextWrapping"      Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding"           Value="8"/>
            <Setter Property="AcceptsReturn"     Value="True"/>
        </Style>
    </Window.Resources>

    <TabControl Margin="8" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderCol}">

        <!-- ═══════════════════════════════════════════════════════════════
             TAB 1 — Decompile (HKX → YAML)
        ════════════════════════════════════════════════════════════════ -->
        <TabItem Header="  Decompile  HKX → YAML  " Foreground="#DCDCDC"
                 Background="{StaticResource PanelBg}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Input HKX file -->
                <Border Grid.Row="0" Style="{StaticResource DropZone}"
                        AllowDrop="True"
                        DragOver="DecompileDrop_DragOver"
                        Drop="DecompileDrop_Drop">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Label}"
                                   Text="INPUT  —  HKX binary file  (drag &amp; drop or browse)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DecompileInput"
                                     Grid.Column="0"
                                     Style="{StaticResource PathBox}"
                                     TextChanged="DecompileInput_TextChanged"/>
                            <Button Grid.Column="2" Content="Browse…"
                                    Style="{StaticResource BrowseBtn}"
                                    Click="BrowseHkx_Click"/>
                        </Grid>
                        <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#666666"
                                   Text="Drop a .hkx file here, or click Browse"/>
                    </StackPanel>
                </Border>

                <!-- Output folder -->
                <StackPanel Grid.Row="2">
                    <TextBlock Style="{StaticResource Label}"
                               Text="OUTPUT  —  YAML source folder"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DecompileOutput"
                                 Grid.Column="0"
                                 Style="{StaticResource PathBox}"/>
                        <Button Grid.Column="2" Content="Browse…"
                                Style="{StaticResource BrowseBtn}"
                                Click="BrowseDecompileOutput_Click"/>
                        <Button Grid.Column="4" Content="Default"
                                Style="{StaticResource BrowseBtn}"
                                Click="DecompileDefault_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Action button -->
                <Button x:Name="DecompileBtn"
                        Grid.Row="4"
                        Content="Decompile"
                        Style="{StaticResource ActionBtn}"
                        IsEnabled="False"
                        Click="Decompile_Click"/>

                <!-- Log -->
                <TextBox x:Name="DecompileLog"
                         Grid.Row="6"
                         Style="{StaticResource LogBox}"/>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════════════
             TAB 2 — Compile (YAML → HKX)
        ════════════════════════════════════════════════════════════════ -->
        <TabItem Header="  Compile  YAML → HKX  " Foreground="#DCDCDC"
                 Background="{StaticResource PanelBg}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Input source folder -->
                <Border Grid.Row="0" Style="{StaticResource DropZone}"
                        AllowDrop="True"
                        DragOver="CompileDrop_DragOver"
                        Drop="CompileDrop_Drop">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Label}"
                                   Text="INPUT  —  YAML source folder  (drag &amp; drop or browse)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CompileInput"
                                     Grid.Column="0"
                                     Style="{StaticResource PathBox}"
                                     TextChanged="CompileInput_TextChanged"/>
                            <Button Grid.Column="2" Content="Browse…"
                                    Style="{StaticResource BrowseBtn}"
                                    Click="BrowseSourceFolder_Click"/>
                        </Grid>
                        <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#666666"
                                   Text="Drop a .hkx source folder here, or click Browse"/>
                    </StackPanel>
                </Border>

                <!-- Output HKX file -->
                <StackPanel Grid.Row="2">
                    <TextBlock Style="{StaticResource Label}"
                               Text="OUTPUT  —  HKX binary file"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CompileOutput"
                                 Grid.Column="0"
                                 Style="{StaticResource PathBox}"/>
                        <Button Grid.Column="2" Content="Browse…"
                                Style="{StaticResource BrowseBtn}"
                                Click="BrowseCompileOutput_Click"/>
                        <Button Grid.Column="4" Content="Default"
                                Style="{StaticResource BrowseBtn}"
                                Click="CompileDefault_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Action button -->
                <Button x:Name="CompileBtn"
                        Grid.Row="4"
                        Content="Compile"
                        Style="{StaticResource ActionBtn}"
                        IsEnabled="False"
                        Click="Compile_Click"/>

                <!-- Log -->
                <TextBox x:Name="CompileLog"
                         Grid.Row="6"
                         Style="{StaticResource LogBox}"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
